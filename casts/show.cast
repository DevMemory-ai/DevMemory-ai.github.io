[3.3, "o", "\u001b[1m# My Project Brain\u001b[0m\r\n\r\n"]
[3.4, "o", "\u001b[1;33m## Codebase Overview\u001b[0m\r\n"]
[3.5, "o", "This is a Node.js Express API server implementing user authentication and task management.\r\n\r\n"]
[3.6, "o", "\u001b[1;33m## Architecture Decisions\u001b[0m\r\n"]
[3.7, "o", "- \u001b[1mJWT-based Authentication\u001b[0m: Tokens issued on login and validated in middleware.\r\n"]
[3.8, "o", "- \u001b[1mSQLite Storage\u001b[0m: Local file database for development simplicity.\r\n\r\n"]
[3.9, "o", "\u001b[1;33m## Key Files & Modules\u001b[0m\r\n"]
[4.0, "o", "- \u001b[36msrc/routes/auth.js\u001b[0m: Handles registration, login, and token generation.\r\n"]
[4.1, "o", "- \u001b[36msrc/middleware/jwt.js\u001b[0m: Incepts incoming requests and verifies bearer tokens.\r\n\r\n"]
